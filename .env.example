# Required: create a Netlify personal access token with read access for the account/sites in scope.
NETLIFY_AUTH_TOKEN=ntl_your_token_here

# Optional: restrict the dashboard to a single Netlify account/team slug.
NETLIFY_ACCOUNT_SLUG=your-team-slug

# Optional: comma-separated Netlify site IDs or site names for business-critical properties.
NETLIFY_SITE_IDS=curatedportal

# Optional: comma-separated production URLs/domains. This supports full Netlify app URLs.
NETLIFY_SITE_URLS=curatedportal.netlify.app

# Optional: cap the number of sites returned and the number receiving deep deploy/form enrichment.
NETLIFY_SITE_LIMIT=24
NETLIFY_DETAIL_LIMIT=8
